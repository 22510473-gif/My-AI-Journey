        self.name=name
        self.__raseed=raseed
        
    def get_raseed(self):
        return self.__raseed
        
    def eedaa(self,many):
        if many > 0:
            self.__raseed+=many
            print("done")
        else:
            print("nooo its erorr")
            
    def saheb(self,many):
        if many>self.__raseed or many <= 0:
            print("erorr")
        else:
            self.__raseed-=many
            
class SavingAccount(Bank):
    def __init__(self,name,raseed,interest_rate):
         super().__init__(name,raseed)
         self.interest_rate=interest_rate
    def apply_interest(self):
        fayda= self.get_raseed()*self.interest_rate
        self.eedaa(fayda)
        
